{
  "mcpServers": {
    "bash": {
      "command": "npx",
      "args": ["bash-mcp"]
    },
    "dotfiles": {
      "command": "/Users/pforsten/.local/bin/uv",
      "args": [
        "run",
        "--project",
        "/Users/pforsten/Development/python/dotfiles-mcp",
        "python",
        "/Users/pforsten/Development/python/dotfiles-mcp/src/main.py"
      ]
    },
    "AbletonMCP": {
      "command": "/Users/pforsten/.local/bin/uvx",
      "args": ["ableton-mcp"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    },
    "svelte": {
      "command": "npx",
      "args": ["-y", "@sveltejs/mcp"]
    }
  }
}
