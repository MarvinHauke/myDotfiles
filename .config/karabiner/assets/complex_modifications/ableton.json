{
  "title": "Ableton Live",
  "rules": [
    {
      "description": "Ableton: Ctrl+Minus öffnet/schließt den Browser (→ Cmd+Option+B)",
      "manipulators": [
        {
          "conditions": [
            {
              "bundle_identifiers": ["^com\\.ableton\\.live*$"],
              "type": "frontmost_application_if"
            }
          ],
          "from": {
            "key_code": "slash",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "5",
              "modifiers": ["left_command", "left_option"]
            }
          ],
          "type": "basic"
        }
      ]
    }
  ]
}
